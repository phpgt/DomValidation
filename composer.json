{
	"name": "phpgt/domvalidation",
	"description": "Server side form validation using web standards.",

	"license": [
		"MIT"
	],

	"type": "library",

	"require": {
		"php": ">=8.2",
		"phpgt/cssxpath": "1.*",
		"phpgt/dom": "^4.1.8"
	},

	"require-dev": {
		"phpunit/phpunit": "^10.0",
		"phpstan/phpstan": "^1.10",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"autoload": {
		"psr-4": {
			"Gt\\DomValidation\\": "./src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Gt\\DomValidation\\Test\\": "./test/phpunit"
		}
	},
	"scripts": {
		"qa": [
			"@qa:phpstan",
			"@qa:phpunit",
			"@qa:phpcs",
			"@qa:phpmd"
		],
		"qa:phpstan": "phpstan analyse src --no-progress",
		"qa:phpunit": "phpunit -c phpunit.xml",
		"qa:phpcs": "phpcs --standard=phpcs.xml src",
		"qa:phpmd": "phpmd src text phpmd.xml"
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
